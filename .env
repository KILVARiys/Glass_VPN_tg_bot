# --- Telegram Bot ---
BOT_TOKEN=

# --- 3x-UI Panel ---
XUI_URL=
XUI_API_TOKEN=
XUI_USERNAME=
XUI_PASSWORD=

XUI_SUB_URL=

# --- Platega.io ---
# Получить в Личном кабинете Platega.io -> Настройки
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET_KEY=

# --- Webhook (приём callback от Platega.io) ---
# Публичный домен с действующим SSL-сертификатом (НЕ self-signed, НЕ localhost/IP)
WEBHOOK_HOST=
# Путь callback'а — должен совпадать с тем, что указан в ЛК Platega.io
# (Настройки -> Callback URLs -> полный адрес = WEBHOOK_HOST + WEBHOOK_PATH)
WEBHOOK_PATH=/platega_callback
# Внутренний порт, на котором слушает Flask (если сервер стоит за Nginx/Caddy —
# это порт, который проксируется наружу через 443/HTTPS)
WEBHOOK_PORT=

# --- Admin ---
ADMIN_ID=
